{
  "name": "@hindsight/mcp-server",
  "version": "0.1.0",
  "private": true,
  "description": "Hindsight MCP server — exposes Guardian findings + NM notes to editors (Cursor / Claude Code / Codex).",
  "type": "module",
  "bin": {
    "hindsight-mcp": "./dist/index.js",
    "hindsight-mcp-install": "./dist/install.js",
    "hindsight-mcp-verify": "./dist/verify.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755); require('node:fs').chmodSync('dist/install.js', 0o755); require('node:fs').chmodSync('dist/verify.js', 0o755);\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:live": "HINDSIGHT_LIVE_CONVEX_URL=$HINDSIGHT_LIVE_CONVEX_URL vitest run server.live",
    "verify": "node dist/verify.js",
    "install:cursor": "node dist/install.js --editor cursor",
    "install:claude-code-project": "node dist/install.js --editor claude-code-project --with-hooks",
    "install:claude-code": "node dist/install.js --editor claude-code --with-hooks",
    "install:codex": "node dist/install.js --editor codex"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "convex": "^1.38.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
